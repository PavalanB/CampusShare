<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing Circle - Represents the sharing community -->
    <path
        android:pathData="M54,54m-42,0a42,42 0 1,1 84,0a42,42 0 1,1 -84,0"
        android:strokeWidth="1.5"
        android:strokeColor="#1AFFFFFF" />

    <!-- Stylized Modern Graduation Cap (Top - Representing Students/Campus) -->
    <path
        android:pathData="M32,45 L54,34 L76,45 L54,56 Z"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M40,51 L40,56 C40,56 46,60 54,60 C62,60 68,56 68,56 L68,51"
        android:fillColor="#FFFFFF" />

    <!-- Two Hands or Arcs (Bottom - Representing Sharing & Giving) -->
    <!-- Re-imagined as professional sleek swooshes -->
    <path
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M35,70 C40,82 68,82 73,70">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="35"
                android:startY="70"
                android:endX="73"
                android:endY="70"
                android:type="linear">
                <item android:offset="0" android:color="#00B4D8"/> <!-- Cyan -->
                <item android:offset="1" android:color="#7209B7"/> <!-- Purple -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center 'Gift/Resource' Dot (Representing the item being shared) -->
    <path
        android:pathData="M54,72 A4,4 0 1,1 53.9,72"
        android:fillColor="#FFFFFF" />

    <!-- A thin line connecting the student (cap) to the share (arc) -->
    <path
        android:pathData="M54,62 L54,66"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="1"
        android:strokeLineCap="round" />

</vector>
