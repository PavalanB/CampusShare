<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Modern Dark Glass Style -->
    <style name="Theme.CampusShare" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSecondaryVariant">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_dark_gradient_start</item>
        <item name="android:windowBackground">@drawable/bg_main_gradient</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>

        <!-- Component Styles -->
        <item name="cardViewStyle">@style/Widget.CampusShare.GlassCard</item>
        <item name="materialButtonStyle">@style/Widget.CampusShare.GlowButton</item>
        <item name="textInputStyle">@style/Widget.CampusShare.GlassInput</item>
        <item name="bottomNavigationStyle">@style/Widget.CampusShare.NormalBottomNav</item>

        <!-- DatePickerDialog Theme -->
        <item name="android:datePickerDialogTheme">@style/Theme.CampusShare.DatePicker</item>
    </style>

    <!-- Custom AlertDialog Style -->
    <style name="CustomAlertDialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <!-- Robust DatePickerDialog Theme for visibility in both modes -->
    <style name="Theme.CampusShare.DatePicker" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorAccent">@color/accent_primary</item>
        <item name="android:windowBackground">@color/bg_card</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Fix for buttons visibility - covering both Material and Android namespaces -->
        <item name="buttonBarPositiveButtonStyle">@style/Widget.CampusShare.DatePicker.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.CampusShare.DatePicker.Button</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/Widget.CampusShare.DatePicker.Button</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/Widget.CampusShare.DatePicker.Button</item>
    </style>

    <style name="Widget.CampusShare.DatePicker.Button" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_primary</item>
        <item name="rippleColor">@color/glass_white_20</item>
    </style>

    <style name="Widget.CampusShare.GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/glass_white_10</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.CampusShare.GlowButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="rippleColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.CampusShare.GlassInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_primary</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">@color/accent_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="enforceTextAppearance">true</item>
        <item name="hintTextAppearance">@style/TextAppearance.CampusShare.Hint</item>
    </style>

    <style name="TextAppearance.CampusShare.Hint" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/accent_primary</item>
    </style>

    <style name="Widget.CampusShare.NormalBottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">12dp</item>
    </style>
</resources>
