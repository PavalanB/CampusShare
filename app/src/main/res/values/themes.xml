<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with Elegant Light Sky Blue & Pink Style -->
    <style name="Theme.CampusShare" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/bg_dark_gradient_start</item>
        <item name="colorPrimaryVariant">#81D4FA</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary_glow</item>
        <item name="colorSecondaryVariant">@color/secondary_glow</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/bg_dark_gradient_start</item>
        <item name="android:windowBackground">@drawable/bg_main_gradient</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-condensed-light</item>

        <!-- Component Styles -->
        <item name="cardViewStyle">@style/Widget.CampusShare.GlassCard</item>
        <item name="materialButtonStyle">@style/Widget.CampusShare.GlowButton</item>
        <item name="textInputStyle">@style/Widget.CampusShare.GlassInput</item>
        <item name="bottomNavigationStyle">@style/Widget.CampusShare.NormalBottomNav</item>
    </style>

    <style name="Widget.CampusShare.GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_white_20</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/white</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.CampusShare.GlowButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_glow</item>
        <item name="rippleColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.CampusShare.GlassInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_glow</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxBackgroundColor">@color/glass_white_10</item>
    </style>

    <style name="Widget.CampusShare.NormalBottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
    </style>
</resources>
