<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/nfs_card_bg">

        <androidx.cardview.widget.CardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="12dp">
            <ImageView
                android:id="@+id/iv_request_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_resource_placeholder" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tv_request_resource_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resource Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/nfs_text_primary" />

            <TextView
                android:id="@+id/tv_request_owner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Owner: Name"
                android:textSize="13sp"
                android:textColor="@color/nfs_text_secondary" />

            <TextView
                android:id="@+id/tv_request_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requested on: Date"
                android:textSize="12sp"
                android:textColor="@color/nfs_text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_request_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="PENDING"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/badge_available" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
