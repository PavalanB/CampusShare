<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Priority strip at top -->
        <TextView
            android:id="@+id/tv_history_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  PRIORITY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:background="#FFF3E0"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:visibility="gone" />

        <!-- Main content row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp">

            <!-- Photo thumbnail -->
            <androidx.cardview.widget.CardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/iv_history_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_resource_placeholder" />
            </androidx.cardview.widget.CardView>

            <!-- Text details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <!-- Name + status badge row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tv_history_resource_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Resource Name"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tv_history_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RETURNED"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/badge_returned" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_history_person"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From: Student Name"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/tv_history_request_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requested: 01 Jan 2025"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorTertiary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_history_returned_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Returned: 08 Jan 2025"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="2dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_history_due_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due: 08 Jan 2025"
                    android:textSize="12sp"
                    android:textColor="#C62828"
                    android:layout_marginBottom="2dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_history_credit_impact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Credit: −1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>

        <!-- Rating row — only visible if rated -->
        <LinearLayout
            android:id="@+id/layout_history_rating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_history_rating_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your rating"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

            <RatingBar
                android:id="@+id/rating_bar_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="1.0"
                android:isIndicator="true"
                style="?android:attr/ratingBarStyleSmall" />

        </LinearLayout>

        <!-- Rate button for borrower/lender -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_history_rate"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="8dp"
            android:text="RATE"
            android:textSize="12sp"
            android:textColor="@color/accent_primary"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
