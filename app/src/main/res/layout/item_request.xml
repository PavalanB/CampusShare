<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Priority banner (amber strip at top) -->
        <TextView
            android:id="@+id/tv_req_priority_badge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  PRIORITY REQUEST"
            android:textColor="#E65100"
            android:textStyle="bold"
            android:textSize="12sp"
            android:background="#FFF3E0"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone" />

        <!-- Content row: photo + details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp">

            <!-- Thumbnail -->
            <ImageView
                android:id="@+id/iv_request_photo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_resource_placeholder" />

            <!-- Text details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tv_req_resource_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Resource Name"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#212121" />

                    <!-- Status badge -->
                    <TextView
                        android:id="@+id/tv_req_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PENDING"
                        android:textSize="10sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/badge_pending" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_req_person"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From: Student Name"
                    android:textSize="13sp"
                    android:textColor="#616161"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/tv_req_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requested: 01 Jan 2025"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/tv_req_due_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due: 08 Jan 2025"
                    android:textSize="12sp"
                    android:textColor="#C62828"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>

        <!-- Action buttons (Accept / Reject / Mark Returned) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btn_reject"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Reject"
                android:textSize="13sp"
                android:textColor="#C62828"
                android:backgroundTint="#FFEBEE"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_accept"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Accept"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E7D32"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_returned"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Mark Returned"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1A237E"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
