<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_login_gradient"
    tools:context=".activities.ForgotPasswordActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btn_back_to_login_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_resource_placeholder"
            android:padding="8dp"
            android:rotation="180"
            app:tint="@color/accent_cyan" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Security Icon -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="80dp"
                app:cardBackgroundColor="#050B18"
                app:cardCornerRadius="50dp"
                app:cardElevation="12dp"
                app:strokeColor="@color/glass_white_20"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="@color/primary_purple" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Title Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="sans-serif-black"
                android:text="SECURITY RECOVERY"
                android:textColor="@color/accent_cyan"
                android:textSize="32sp"
                android:letterSpacing="0.1"
                android:shadowColor="@color/accent_cyan"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Verify your identity to regain access"
                android:textColor="@color/glass_white_80"
                android:textSize="14sp"
                android:fontFamily="serif" />

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardBackgroundColor="#CC1A1C2C"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_white_10"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="30dp">

                    <!-- Email Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="SECURE EMAIL"
                        android:layout_marginBottom="24dp"
                        app:hintTextColor="@color/accent_cyan"
                        android:textColorHint="@color/accent_cyan"
                        app:boxStrokeColor="@color/accent_cyan"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="@color/accent_cyan"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_send_reset"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="INITIATE RECOVERY"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/accent_cyan"
                        android:textColor="#050B18"
                        android:fontFamily="sans-serif-black"
                        android:textSize="14sp" />

                    <ProgressBar
                        android:id="@+id/progress_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:layout_marginTop="16dp"
                        android:indeterminateTint="@color/accent_cyan" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/btn_back_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="20dp"
                android:text="ABORT AND RETURN"
                android:textColor="@color/primary_purple"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textSize="14sp"
                android:padding="12dp" />

        </LinearLayout>
    </RelativeLayout>
</ScrollView>
