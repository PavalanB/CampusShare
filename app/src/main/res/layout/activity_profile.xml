<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIconTint="@color/nfs_text_primary"
            app:titleTextColor="@color/nfs_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- DECORATIVE ELEMENTS -->
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="-20dp"
                android:layout_marginTop="20dp"
                android:alpha="0.4"
                android:rotation="-20"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/nfs_purple_glow"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="-10dp"
                android:layout_marginTop="100dp"
                android:alpha="0.4"
                android:rotation="15"
                android:src="@android:drawable/ic_menu_slideshow"
                app:tint="@color/nfs_blue_accent"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="20dp">

                <!-- Profile Picture Circle -->
                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="30dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="15dp"
                    app:cardBackgroundColor="@color/nfs_bg_dark_fixed">
                    <TextView
                        android:id="@+id/tv_initials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="PB"
                        android:textSize="40sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/white" />
                </androidx.cardview.widget.CardView>

                <!-- Profile Name & Dept -->
                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Student Name"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold|italic"
                    android:textColor="@color/nfs_text_primary"
                    android:shadowColor="@color/nfs_blue_accent"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="8" />

                <TextView
                    android:id="@+id/tv_profile_dept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Information Technology • 2nd Year"
                    android:textSize="14sp"
                    android:textColor="@color/nfs_text_secondary"
                    android:layout_marginBottom="25dp" />

                <!-- Stats Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="15dp"
                    app:cardBackgroundColor="@color/nfs_card_bg"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_credit_score"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="850"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="@color/nfs_purple_glow" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/credit_score"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/nfs_text_secondary"
                                android:letterSpacing="0.1" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/nfs_blue_accent"
                            android:alpha="0.3" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_avg_rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4.8"
                                android:textSize="24sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="@color/nfs_blue_accent" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/user_rating"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/nfs_text_secondary"
                                android:letterSpacing="0.1" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Details Section -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="10dp"
                    app:cardBackgroundColor="@color/nfs_card_bg"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/info_label"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/nfs_purple_glow"
                            android:letterSpacing="0.2"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_info_details"
                                app:tint="@color/nfs_blue_accent"
                                android:contentDescription="@null" />
                            <TextView
                                android:id="@+id/tv_profile_college_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:text="ID: CS2021001"
                                android:textColor="@color/nfs_text_primary" />
                        </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_dialog_email"
                            app:tint="@color/nfs_blue_accent"
                            android:contentDescription="@null" />
                        <TextView
                            android:id="@+id/tv_profile_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="pavalan@college.edu"
                            android:textColor="@color/nfs_text_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/nfs_blue_accent"
                            android:contentDescription="@null" />
                        <TextView
                            android:id="@+id/tv_profile_phone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="+91 9876543210"
                            android:textColor="@color/nfs_text_primary" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actions Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="@color/nfs_card_bg"
                android:layout_marginBottom="20dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_history"
                style="@style/Widget.CampusShare.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="View My Borrowing History"
                android:textSize="15sp"
                android:textColor="@color/primary_glow"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/rl_my_listings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ic_tools"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/nfs_purple_glow"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ic_tools"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"
                            android:text="@string/my_listings"
                            android:textStyle="bold"
                            android:textColor="@color/nfs_text_primary"
                            android:letterSpacing="0.1" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/nfs_blue_accent"
                            android:contentDescription="@null" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/nfs_blue_accent"
                        android:alpha="0.2"
                        android:layout_marginHorizontal="20dp" />

                    <RelativeLayout
                        android:id="@+id/rl_borrow_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ic_hist"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="@color/nfs_purple_glow"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ic_hist"
                            android:layout_marginStart="16dp"
                            android:layout_centerVertical="true"
                            android:text="@string/borrow_history"
                            android:textStyle="bold"
                            android:textColor="@color/nfs_text_primary"
                            android:letterSpacing="0.1" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/nfs_blue_accent"
                            android:contentDescription="@null" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/logout"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/nfs_purple_glow"
                app:cornerRadius="15dp"
                android:layout_marginBottom="30dp"
                android:elevation="10dp" />

            </LinearLayout>
        </RelativeLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
