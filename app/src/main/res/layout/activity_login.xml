<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/login_background">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- DECORATIVE ELEMENTS (Neon Student Tools) -->
        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="-20dp"
            android:layout_marginTop="20dp"
            android:alpha="0.4"
            android:rotation="-20"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/nfs_purple_glow" />

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="-10dp"
            android:layout_marginTop="100dp"
            android:alpha="0.4"
            android:rotation="15"
            android:src="@android:drawable/ic_menu_slideshow"
            app:tint="@color/nfs_blue_accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <!-- Profile Picture / Logo at Top -->
            <androidx.cardview.widget.CardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="30dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="15dp"
                app:cardBackgroundColor="@color/nfs_bg_dark_fixed">
                <ImageView
                    android:id="@+id/iv_profile_top"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:src="@drawable/ic_login_symbol"
                    android:scaleType="centerInside"
                    app:tint="@color/white" />
            </androidx.cardview.widget.CardView>

            <!-- NFS Heat Inspired App Name -->
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/tv_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAMPUS"
                    android:textSize="50sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold|italic"
                    android:textColor="@color/nfs_text_primary"
                    android:letterSpacing="-0.05"
                    android:paddingEnd="10dp"
                    android:shadowColor="@color/nfs_blue_accent"
                    android:shadowDx="5"
                    android:shadowDy="5"
                    android:shadowRadius="12" />

                <TextView
                    android:id="@+id/tv_app_name_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_app_name"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="-30dp"
                    android:rotation="-5"
                    android:text="Share"
                    android:textSize="60sp"
                    android:fontFamily="cursive"
                    android:textStyle="bold|italic"
                    android:textColor="@color/nfs_text_primary"
                    android:paddingStart="15dp"
                    android:paddingEnd="15dp"
                    android:paddingBottom="8dp"
                    android:shadowColor="@color/nfs_purple_glow"
                    android:shadowDx="5"
                    android:shadowDy="5"
                    android:shadowRadius="18" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Campus Resource Hub"
                android:textSize="12sp"
                android:textColor="@color/nfs_text_secondary"
                android:layout_marginBottom="25dp" />

            <!-- Login Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="20dp"
                app:cardBackgroundColor="@color/nfs_card_bg"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="30dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Login"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/nfs_text_primary"
                        android:layout_marginBottom="24dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email Address"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="16dp"
                        app:startIconDrawable="@android:drawable/ic_dialog_email"
                        app:startIconTint="@color/nfs_blue_accent"
                        app:boxStrokeColor="@color/nfs_blue_accent"
                        app:hintTextColor="@color/nfs_blue_accent"
                        android:textColorHint="@color/nfs_text_secondary"
                        app:boxCornerRadiusTopStart="15dp"
                        app:boxCornerRadiusTopEnd="15dp"
                        app:boxCornerRadiusBottomStart="15dp"
                        app:boxCornerRadiusBottomEnd="15dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/nfs_text_primary"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                        app:startIconTint="@color/nfs_purple_glow"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/nfs_text_secondary"
                        android:layout_marginBottom="8dp"
                        app:boxStrokeColor="@color/nfs_purple_glow"
                        app:hintTextColor="@color/nfs_purple_glow"
                        android:textColorHint="@color/nfs_text_secondary"
                        app:boxCornerRadiusTopStart="15dp"
                        app:boxCornerRadiusTopEnd="15dp"
                        app:boxCornerRadiusBottomStart="15dp"
                        app:boxCornerRadiusBottomEnd="15dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/nfs_text_primary"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tv_forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="Forgot Password?"
                        android:textColor="@color/nfs_blue_accent"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginBottom="32dp" />

                    <Button
                        android:id="@+id/btn_login"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="LOGIN"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/nfs_purple_glow"
                        app:cornerRadius="15dp"
                        android:elevation="10dp" />

                    <ProgressBar
                        android:id="@+id/progress_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:indeterminate="true"
                        android:visibility="gone"
                        app:indicatorColor="@color/nfs_blue_accent" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New to CampusShare? "
                    android:textColor="@color/nfs_text_secondary"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tv_register"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    android:textColor="@color/nfs_blue_accent"
                    android:textStyle="bold"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>
    </RelativeLayout>
</ScrollView>
