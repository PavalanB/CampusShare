<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_splash"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Circular Avatar Placeholder -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_logo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardBackgroundColor="#050B18"
            app:cardCornerRadius="70dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/glass_white_10"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_resource_placeholder"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Main Title with Neon Effect -->
        <TextView
            android:id="@+id/tv_app_name_main"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:fontFamily="sans-serif-black"
            android:text="CAMPUS"
            android:textColor="@color/accent_cyan"
            android:textSize="48sp"
            android:letterSpacing="0.1"
            android:shadowColor="@color/accent_cyan"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="20" />

        <TextView
            android:id="@+id/tv_app_name_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-10dp"
            android:fontFamily="cursive"
            android:text="Share"
            android:textColor="@color/white"
            android:textSize="64sp"
            android:textStyle="bold"
            android:shadowColor="@color/primary_purple"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="25" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="ACCESSING SECURE SERVER..."
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:fontFamily="sans-serif-condensed" />

        <ProgressBar
            style="@style/Widget.MaterialComponents.LinearProgressIndicator"
            android:layout_width="200dp"
            android:layout_height="2dp"
            android:layout_marginTop="16dp"
            android:indeterminate="true"
            app:indicatorColor="@color/primary_purple"
            app:trackColor="@color/glass_white_10" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ESTABLISHING SECURE CONNECTION"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-condensed-light" />

    </LinearLayout>

</RelativeLayout>
